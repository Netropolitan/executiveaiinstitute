---
import '../styles/theme.css';
import Subscribe from '../components/Subscribe.astro';
const {
  title = 'Executive AI Institute | Leadership For The Age Of AI',
  description = 'The Executive AI Institute equips senior leaders with people-first AI strategy — world-class leadership psychology meets deep technical mastery.',
  noindex = false,
  hideSubscribe = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const path = Astro.url.pathname;
const current = (href) => (href === '/' ? path === '/' : path.startsWith(href)) ? 'page' : undefined;
const nav = [
  { href: '/about/', label: 'About' },
  { href: '/programs/', label: 'Programs' },
  { href: '/coaching/', label: 'Coaching' },
  { href: '/insights/', label: 'Insights' },
  { href: '/events/', label: 'Events' },
  { href: '/contact/', label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#070b09" />
  <meta property="og:site_name" content="Executive AI Institute" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <script is:inline>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400;1,9..40,500&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>

  <header class="site-header">
    <div class="nav">
      <a class="brand" href="/" aria-label="Executive AI Institute home">
        <svg class="mark" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <circle cx="20" cy="20" r="18.5" stroke="#059669" stroke-width="1.6" opacity="0.55"/>
          <path d="M11 27 L18.5 19 L24 22.5 L30 12.5" stroke="#A7D8C4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="11" cy="27" r="2.6" fill="#059669"/>
          <circle cx="18.5" cy="19" r="2.6" fill="#059669"/>
          <circle cx="24" cy="22.5" r="2.6" fill="#059669"/>
          <circle cx="30" cy="12.5" r="3.2" fill="#FAF8F4"/>
        </svg>
        <b>Executive AI Institute</b>
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>
      <nav class="nav-links" aria-label="Primary">
        {nav.map((n) => <a href={n.href} aria-current={current(n.href)}>{n.label}</a>)}
        <a class="btn btn--solid" href="/roadmap/">Leadership Roadmap</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  {!hideSubscribe && <Subscribe />}

  <footer class="site-footer">
    <div class="container">
      <div class="foot-grid">
        <div>
          <a class="brand" href="/" style="margin-bottom:16px">
            <svg class="mark" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <circle cx="20" cy="20" r="18.5" stroke="#059669" stroke-width="1.6" opacity="0.55"/>
              <path d="M11 27 L18.5 19 L24 22.5 L30 12.5" stroke="#A7D8C4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="11" cy="27" r="2.6" fill="#059669"/>
              <circle cx="18.5" cy="19" r="2.6" fill="#059669"/>
              <circle cx="24" cy="22.5" r="2.6" fill="#059669"/>
              <circle cx="30" cy="12.5" r="3.2" fill="#FAF8F4"/>
            </svg>
            <b>Executive AI Institute</b>
          </a>
          <p style="max-width:44ch">Leadership for the age of AI. People-first strategy, ethical governance and hands-on capability for senior executives and their organisations.</p>
        </div>
        <div>
          <h3>Institute</h3>
          <div style="margin:7px 0"><a href="/about/">About</a></div>
          <div style="margin:7px 0"><a href="/programs/">Programs</a></div>
          <div style="margin:7px 0"><a href="/coaching/">Coaching</a></div>
          <div style="margin:7px 0"><a href="/roadmap/">Leadership Roadmap</a></div>
        </div>
        <div>
          <h3>Connect</h3>
          <div style="margin:7px 0"><a href="/insights/">Insights</a></div>
          <div style="margin:7px 0"><a href="/events/">Events</a></div>
          <div style="margin:7px 0"><a href="/contact/">Contact</a></div>
          <div style="margin:7px 0"><a href="/faq/">FAQ</a></div>
        </div>
      </div>
      <div class="foot-bottom">
        <span>© 2026 Executive AI Institute. All rights reserved.</span>
        <span><a href="/privacy/">Privacy Policy</a></span>
      </div>
    </div>
  </footer>

  <script>
    // Mobile nav
    const t = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    t?.addEventListener('click', () => {
      const open = links?.classList.toggle('open');
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Reveal-on-scroll
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add('in')),
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</body>
</html>
