---
import Base from '../layouts/Base.astro';
// Contact form posts via mailto fallback until the form backend is wired
// (Brew form endpoint or Formspree — decide at publish time with Jonscott).
const interests = [
  "EAII's services for my organisation",
  "EAII's services for personal development",
  'Executive AI coaching',
  'Strategic partnership',
  'Investment',
  'Hosting or collaborating on an event',
  'Press / speaking enquiry',
];
---
<Base title="Contact | Executive AI Institute" description="Start a conversation with the Executive AI Institute — programs, coaching, partnerships and events.">
  <section class="section container" style="padding-top:160px">
    <div class="contact-grid">
      <div>
        <span class="kicker">Contact us</span>
        <h1 style="max-width:12ch">Start the <span class="accent">conversation.</span></h1>
        <p class="lead" style="margin-top:24px">Tell us where you are on the AI journey and what you're trying to move. We reply personally — usually within one working day.</p>
        <div class="alt">
          <p style="margin-bottom:6px"><b style="color:var(--cream)">Prefer a diagnosis first?</b></p>
          <p style="font-size:15.5px">Take the <a href="/roadmap/">AI Leadership Roadmap</a> and book a debrief with your report in hand.</p>
        </div>
      </div>

      <form class="card" id="contactForm" novalidate>
        <div class="two">
          <div class="field">
            <label for="fn">First name *</label>
            <input id="fn" name="firstName" type="text" required autocomplete="given-name" />
          </div>
          <div class="field">
            <label for="ln">Last name *</label>
            <input id="ln" name="lastName" type="text" required autocomplete="family-name" />
          </div>
        </div>
        <div class="field">
          <label for="em">Email *</label>
          <input id="em" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="co">Company name</label>
          <input id="co" name="company" type="text" autocomplete="organization" />
        </div>
        <div class="field">
          <label for="interest">I'm interested in…</label>
          <select id="interest" name="interest">
            {interests.map((i) => <option>{i}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="msg">Message</label>
          <textarea id="msg" name="message" rows="5"></textarea>
        </div>
        <button class="btn btn--solid btn--lg" type="submit" style="width:100%;justify-content:center">Send message</button>
        <p id="formNote" style="font-size:13.5px;color:var(--faint);margin:14px 0 0;text-align:center">Your message opens in your email client addressed to the Institute.</p>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    const d = new FormData(form);
    const subject = encodeURIComponent(`Website enquiry — ${d.get('interest')}`);
    const body = encodeURIComponent(
      `Name: ${d.get('firstName')} ${d.get('lastName')}\nEmail: ${d.get('email')}\nCompany: ${d.get('company') || '—'}\nInterested in: ${d.get('interest')}\n\n${d.get('message') || ''}`
    );
    window.location.href = `mailto:hello@executiveaiinstitute.com?subject=${subject}&body=${body}`;
  });
</script>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(32px, 5vw, 80px); align-items: start; }
  @media (max-width: 860px) { .contact-grid { grid-template-columns: 1fr; } }
  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 480px) { .two { grid-template-columns: 1fr; } }
  .alt { margin-top: 44px; padding-top: 30px; border-top: 1px solid var(--line); }
</style>
