---
import Base from '../layouts/Base.astro';
// Joint EAII × Bykov-Brett reports (e.g. The State of AI briefings). The list
// comes live from the backend, so publishing a report with the /reports skill
// puts it on both this site and bykovbrett.net/reports automatically.
// Access is gated like the roadmap: name + work email + company, recorded to
// the EAII Subscribers list tagged source=report.
//
// File delivery: the /reports publishing pipeline uploads `<slug>.pdf` and
// `<slug>-cover.jpg` side by side on the HubSpot CDN, so the PDF URL is derived
// from feature_image_url. If that convention ever breaks, the canonical gated
// landing page (item.url) is offered as the fallback link.
const REPORTS_API = 'https://api.runrevolution.org/api/hygiene/public/reports';
const LEAD_ENDPOINT = 'https://api.runrevolution.org/api/automations/webhook/24/2bd446c001536638f15b1901a3851dd2';
---
<Base title="Reports | Executive AI Institute" description="Enterprise AI briefings and research reports from the Executive AI Institute and Bykov-Brett Enterprises. Free access with your work email.">
  <section class="section container" style="padding-top:160px;padding-bottom:48px">
    <span class="kicker">Reports</span>
    <h1 style="max-width:15ch">Briefings worth <span class="accent">forwarding.</span></h1>
    <p class="lead" style="margin-top:24px">
      Enterprise AI briefings and research reports, published jointly with Bykov-Brett
      Enterprises. Free with your work email; written to be walked into your next
      leadership meeting.
    </p>
  </section>

  <section class="container" style="padding-bottom:120px">
    <div id="reports" data-api={REPORTS_API} data-lead={LEAD_ENDPOINT}>
      <div class="card" style="text-align:center;padding:64px 28px;max-width:640px;margin:0 auto">
        <h2 style="font-size:clamp(22px,2.4vw,30px)">Reports are loading</h2>
        <p style="margin:0 auto;max-width:46ch">If nothing appears in a moment, <a href="/contact/">ask us directly</a> and we will send you the latest briefing.</p>
      </div>
    </div>

    <!-- Access gate dialog -->
    <dialog id="gate" class="gate">
      <form id="gateForm" method="dialog" novalidate>
        <p class="gate-kicker">Free access</p>
        <h2 id="gateTitle" style="font-size:clamp(20px,2.2vw,28px)">Get the report</h2>
        <p style="font-size:15px">Tell us who the report is for and the download starts straight away.</p>
        <div class="field">
          <label for="gName">Full name *</label>
          <input id="gName" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="gCompany">Company *</label>
          <input id="gCompany" name="company" type="text" required autocomplete="organization" />
        </div>
        <div class="field">
          <label for="gEmail">Work email *</label>
          <input id="gEmail" name="email" type="email" required autocomplete="email" />
        </div>
        <input class="g-hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="gate-actions">
          <button class="btn btn--solid" type="submit">Get the report</button>
          <button class="btn btn--ghost" type="button" id="gateCancel">Cancel</button>
        </div>
        <p style="font-size:12.5px;color:var(--faint);margin:14px 0 0">We only use this to send the report and occasional leadership briefings. Unsubscribe any time. <a href="/privacy/">Privacy policy</a>.</p>
      </form>
    </dialog>
  </section>
</Base>

<script>
  const root = document.getElementById('reports');
  const gate = document.getElementById('gate') as HTMLDialogElement;
  const gateForm = document.getElementById('gateForm') as HTMLFormElement;
  const gateTitle = document.getElementById('gateTitle');
  let active: { title: string; pdf: string; page: string } | null = null;

  const esc = (s: string) => (s || '').replace(/[&<>"']/g, (c) =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  const pdfFrom = (cover: string) => cover && cover.includes('-cover.') ? cover.replace(/-cover\.(jpg|jpeg|png)$/i, '.pdf') : '';

  if (root) {
    fetch(root.dataset.api as string)
      .then((r) => (r.ok ? r.json() : Promise.reject()))
      .then((reports: any[]) => {
        if (!Array.isArray(reports) || !reports.length) {
          root.innerHTML = `
            <div class="card" style="text-align:center;padding:64px 28px;max-width:640px;margin:0 auto">
              <h2 style="font-size:clamp(22px,2.4vw,30px)">The first report lands soon</h2>
              <p style="margin:0 auto;max-width:46ch"><a href="/contact/">Tell us you want it</a> and we will send it the day it publishes.</p>
            </div>`;
          return;
        }
        const card = (r: any, featured: boolean) => `
          <article class="rep ${featured ? 'rep--feature' : ''}">
            ${r.feature_image_url ? `<div class="rep-img"><img src="${esc(r.feature_image_url)}" alt="" loading="lazy" /></div>` : ''}
            <div class="rep-body">
              ${featured ? '<span class="rep-tag">Latest report</span>' : ''}
              <h2 class="rep-title">${esc(r.title)}</h2>
              <p class="rep-desc">${esc(r.description || '')}</p>
              <button class="btn btn--solid rep-get" data-title="${esc(r.title)}"
                data-pdf="${esc(pdfFrom(r.feature_image_url || ''))}" data-page="${esc(r.url)}">Get the report</button>
            </div>
          </article>`;
        root.innerHTML = `
          ${card(reports[0], true)}
          ${reports.length > 1 ? `<h3 class="rep-archive-h">Earlier reports</h3><div class="rep-grid">${reports.slice(1).map((r) => card(r, false)).join('')}</div>` : ''}`;

        root.querySelectorAll('.rep-get').forEach((b) => {
          b.addEventListener('click', () => {
            const el = b as HTMLElement;
            active = { title: el.dataset.title || '', pdf: el.dataset.pdf || '', page: el.dataset.page || '' };
            if (gateTitle) gateTitle.textContent = active.title;
            gate?.showModal();
          });
        });
      })
      .catch(() => { /* keep the loading/fallback card */ });
  }

  document.getElementById('gateCancel')?.addEventListener('click', () => gate?.close());

  gateForm?.addEventListener('submit', (e) => {
    if (!gateForm.reportValidity()) { e.preventDefault(); return; }
    const d = new FormData(gateForm);
    if (d.get('website') || !active) return;
    fetch(root?.dataset.lead as string, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: String(d.get('email') || '').trim(),
        name: String(d.get('name') || '').trim(),
        company: String(d.get('company') || '').trim(),
        source: `report: ${active.title}`,
      }),
    }).catch(() => { /* never block the download */ });
    const target = active.pdf || active.page;
    window.open(target, '_blank', 'noopener');
    gateForm.reset();
  });
</script>

<style is:global>
  .rep {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: stretch;
    border: 1px solid var(--line-strong);
    border-radius: 22px;
    overflow: hidden;
    background:
      radial-gradient(100% 130% at 100% 0%, rgba(5, 150, 105, 0.14), transparent 55%),
      linear-gradient(160deg, var(--pine), var(--onyx));
  }
  /* The cover drives the card height: the image sits at its natural width
     (100% of its own column, so it can never overflow into the text) and the
     body stretches to that height, centring its content. */
  .rep--feature .rep-body {
    padding: clamp(24px, 3.5vw, 48px) clamp(28px, 4vw, 56px) clamp(24px, 3.5vw, 48px) 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .rep-img { display: flex; align-items: center; }
  .rep-img img { width: 100%; height: auto; object-fit: contain; display: block; }
  .rep-desc { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .rep-get { align-self: flex-start; } /* only as wide as its text, not the column */
  .rep-tag {
    display: inline-block;
    font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--emerald); margin-bottom: 14px;
  }
  .rep-title { font-size: clamp(24px, 3vw, 40px); margin-bottom: 12px; }
  .rep-desc { font-size: 15.5px; margin-bottom: 26px; max-width: 56ch; }
  @media (max-width: 820px) {
    .rep { grid-template-columns: 1fr; }
    .rep--feature .rep-body { padding: 0 26px 30px; }
  }

  .rep-archive-h {
    font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--emerald); margin: 44px 0 18px;
  }
  .rep-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 22px; }
  .rep-grid .rep { grid-template-columns: 1fr; align-items: start; }
  .rep-grid .rep-body { padding: 0 24px 26px; }
  .rep-grid .rep-title { font-size: clamp(19px, 1.9vw, 24px); }

  .gate {
    border: 1px solid var(--line-strong);
    border-radius: 20px;
    background: linear-gradient(160deg, var(--pine), var(--onyx));
    color: var(--cream);
    padding: clamp(26px, 3vw, 40px);
    width: min(480px, calc(100vw - 40px));
  }
  .gate::backdrop { background: rgba(7, 11, 9, 0.8); backdrop-filter: blur(4px); }
  .gate-kicker { font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--emerald); margin: 0 0 8px; }
  .gate-actions { display: flex; gap: 10px; margin-top: 6px; }
  .g-hp { position: absolute; left: -9999px; width: 1px; height: 1px; }
</style>
