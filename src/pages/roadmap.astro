---
import Base from '../layouts/Base.astro';
// AI Leadership Roadmap. The original Typebot version asked 36 questions and
// round-tripped three LLM prompts; this version asks 12 (three per dimension),
// scores deterministically client-side, and renders a scorecard report on the
// page. Results are gated behind name + work email + company; the details POST
// to the Brew signup funnel tagged source=roadmap.
//
// NOTE: every element the quiz/report injects with JS must be styled in the
// is:global block below. Astro-scoped styles never match runtime-created nodes.
---
<Base title="AI Leadership Roadmap | Executive AI Institute" description="A free diagnostic for senior leaders: answer 12 questions and get your AI leadership scorecard with maturity stages, blindspots, opportunities and recommendations.">
  <section class="section container" style="padding-top:160px;padding-bottom:40px">
    <span class="kicker">Free diagnostic · 3 minutes</span>
    <h1 style="max-width:15ch">Your AI Leadership <span class="accent">Roadmap.</span></h1>
    <p class="lead" style="margin-top:24px">
      Twelve questions across four dimensions: leadership readiness, organisational maturity,
      culture &amp; adoption, governance &amp; risk. There are no right or wrong answers. Your
      responses reveal strengths, gaps and the next moves on your AI journey.
    </p>
  </section>

  <section class="container" style="padding-bottom:120px">
    <div id="quiz" class="card quiz">
      <!-- Intro -->
      <div class="q-step" data-step="intro">
        <h2 style="font-size:clamp(24px,2.6vw,34px)">Before we start</h2>
        <p>Answer for the organisation you lead or advise. The diagnostic measures:</p>
        <ul class="dims">
          <li><b>Leadership readiness</b>: your own grasp of AI and ability to direct it</li>
          <li><b>Organisational maturity</b>: what your organisation has actually done</li>
          <li><b>Culture &amp; adoption</b>: how your people respond to change</li>
          <li><b>Governance &amp; risk</b>: how you manage what can go wrong</li>
        </ul>
        <button class="btn btn--solid btn--lg" id="startBtn" style="margin-top:26px">Begin the diagnostic</button>
      </div>

      <!-- Questions injected here -->
      <div class="q-step" data-step="question" hidden>
        <div class="q-progress"><div class="q-bar" id="qBar"></div></div>
        <p class="q-dim" id="qDim"></p>
        <h2 class="q-text" id="qText" style="font-size:clamp(22px,2.4vw,30px)"></h2>
        <div class="q-options" id="qOptions" role="group"></div>
      </div>

      <!-- Details gate: the scorecard unlocks with name, work email and company -->
      <div class="q-step" data-step="details" hidden>
        <div class="q-progress"><div class="q-bar" style="width:100%"></div></div>
        <p class="q-dim">One last step</p>
        <h2 style="font-size:clamp(22px,2.4vw,30px)">Your scorecard is ready. Who is it for?</h2>
        <p>We prepare the scorecard under your name and company so you can share it with your leadership team.</p>
        <form id="detailsForm" novalidate>
          <div class="two">
            <div class="field">
              <label for="dName">Full name *</label>
              <input id="dName" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="dCompany">Company *</label>
              <input id="dCompany" name="company" type="text" required autocomplete="organization" />
            </div>
          </div>
          <div class="field">
            <label for="dEmail">Work email *</label>
            <input id="dEmail" name="email" type="email" required autocomplete="email" />
          </div>
          <!-- Honeypot -->
          <input class="d-hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button class="btn btn--solid btn--lg" type="submit">Show my scorecard</button>
          <p style="font-size:13px;color:var(--faint);margin:14px 0 0">We only use this to send your scorecard and occasional leadership briefings. Unsubscribe any time. <a href="/privacy/">Privacy policy</a>.</p>
        </form>
      </div>
    </div>

    <!-- Scorecard report (all inner markup injected by the script below) -->
    <div id="report" hidden></div>
  </section>
</Base>

<script>
  // ── Question bank: 4 dimensions × 3 questions, options scored 0-3 ──
  const DIMS = ['Leadership readiness', 'Organisational maturity', 'Culture & adoption', 'Governance & risk'];
  const QS = [
    { d: 0, q: 'How confident are you in explaining core AI concepts to your team?',
      o: ['Not confident at all', 'Somewhat unsure', 'Fairly confident', 'Very confident'] },
    { d: 0, q: 'Which best describes your current AI knowledge?',
      o: ['No knowledge', 'Basic awareness of the terms', 'Moderate understanding of uses and limits', 'Deep understanding of strategy and ethics'] },
    { d: 0, q: 'How well can your leadership articulate why AI matters to your top business goals?',
      o: ['We haven’t connected the two', 'In broad strokes only', 'For some functions, clearly', 'A crisp, shared narrative across the exec team'] },
    { d: 1, q: 'Which step has your organisation already taken toward AI?',
      o: ['None', 'Informal research or discussion', 'A small pilot or proof-of-concept', 'Multiple pilots or early deployments'] },
    { d: 1, q: 'How well do you understand your organisation’s data, technology and process limits for deploying AI?',
      o: ['Not at all', 'A rough sense', 'Mapped for key functions', 'Mapped, owned and regularly reviewed'] },
    { d: 1, q: 'When planning AI initiatives, how often are they linked to specific KPIs or ROI targets?',
      o: ['Never, we haven’t planned any', 'Rarely', 'Usually', 'Always, it’s a gate for funding'] },
    { d: 2, q: 'How does your organisation react when someone says “we should try AI”?',
      o: ['Resistant, not interested', 'Resistant but curious, needs proof', 'Open with caution, needs more info', 'Very open, let’s do it'] },
    { d: 2, q: 'How easily does your team pick up new digital skills?',
      o: ['Very hard', 'Somewhat hard', 'Somewhat easy', 'Very easy'] },
    { d: 2, q: 'How often do teams share tips and help each other with new tools?',
      o: ['Never', 'Sometimes', 'Often', 'Always'] },
    { d: 3, q: 'Which best describes your approach to managing AI-related risks?',
      o: ['We haven’t considered them', 'Ad hoc, handled if they appear', 'Defined guidelines for key risks', 'A living governance framework with clear owners'] },
    { d: 3, q: 'How often do you invite outside experts or sceptics to challenge your AI plans?',
      o: ['Never', 'Rarely', 'Sometimes', 'Frequently'] },
    { d: 3, q: 'How are mistakes made with a new tool treated?',
      o: ['Someone gets blamed', 'Quietly buried', 'Tolerated', 'Examined openly as learning material'] },
  ];

  const LEAD_STAGES = ['Emerging', 'Strategic', 'Governance', 'Transformative'];
  const ORG_STAGES = ['Exploratory', 'Foundational', 'Integrated', 'Transformational'];
  const ADOPT_STAGES = ['Unaware', 'Skepticism', 'Exploration', 'Adoption', 'Institutionalised'];
  const TRAIN_STAGES = ['Awareness & strategy', 'Leadership development', 'Organisational capability', 'Continuous learning'];
  const GRADES = [
    { min: 0.85, g: 'A', label: 'Front-runner' },
    { min: 0.65, g: 'B', label: 'Building momentum' },
    { min: 0.45, g: 'C', label: 'Ready to move' },
    { min: 0.25, g: 'D', label: 'Early days' },
    { min: 0, g: 'E', label: 'Starting line' },
  ];

  const BLIND = [
    { h: 'Fluency gap', b: 'Leadership conviction is running ahead of leadership understanding. Strategy set today will be inherited from vendors, not chosen.' },
    { h: 'Invisible foundations', b: 'Ambition is outpacing knowledge of your own data, process and technology limits. This is the most common cause of stalled pilots.' },
    { h: 'Quiet resistance', b: 'Initiatives are being green-lit faster than the culture can absorb them; adoption will lag announcement.' },
    { h: 'Unowned risk', b: 'No one is formally accountable for AI risk. Fine until the first incident, expensive afterwards.' },
  ];
  const OPPS = [
    { h: 'Leadership upskilling', b: 'A structured executive AI fluency program converts enthusiasm into judgement. It is the fastest-compounding investment available to you.' },
    { h: 'Process quick wins', b: 'Manual, repeatable work in your operations is the natural first deployment: visible value in weeks, low risk, high learning.' },
    { h: 'Champion network', b: 'Your most curious people are an unbuilt asset. A champions program turns scattered experimentation into organisational capability.' },
    { h: 'Governance as advantage', b: 'Codifying how you evaluate, approve and monitor AI use builds the trust, internal and external, that accelerates everything else.' },
  ];
  const RECS = [
    { h: 'Executive briefing', b: 'Run a cost-of-inaction briefing with the full leadership team to build a shared, realistic baseline.' },
    { h: 'Readiness audit', b: 'Map your data, technology and process constraints before committing to any flagship initiative.' },
    { h: 'Pilot with guardrails', b: 'Launch one scoped pilot tied to a named KPI, with oversight rules agreed before kick-off.' },
    { h: 'Capability cadence', b: 'Stand up a regular upskilling rhythm. Micro-labs, not one-off training days, so capability compounds.' },
  ];
  const RISKS = [
    ['1 year', 'Operational inefficiencies persist while competitors automate; the best digitally-fluent talent starts choosing employers who are visibly moving.'],
    ['3 years', 'Competitive dynamics shift: rivals price and respond on AI-assisted cost curves you cannot match, and market share erosion accelerates.'],
    ['5 years', 'Strategic obsolescence sets in. Product cycles, customer expectations and margins are set by AI-native operators in your sector.'],
    ['10 years', 'Catch-up costs exceed transformation costs several times over; the question becomes viability, not advantage.'],
  ];

  // ── State ──
  const answers = new Array(QS.length).fill(-1);
  let idx = 0;
  let org = '';
  let person = '';

  // Lead capture posts to the Brew signup funnel tagged source=roadmap.
  // Network failure never blocks the scorecard.
  const LEAD_ENDPOINT = 'https://eaii.taila07ff3.ts.net/api/automations/webhook/24/2bd446c001536638f15b1901a3851dd2';

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  const introEl = document.querySelector('[data-step="intro"]');
  const qEl = document.querySelector('[data-step="question"]');
  const detailsEl = document.querySelector('[data-step="details"]');

  $('startBtn')?.addEventListener('click', () => {
    introEl?.setAttribute('hidden', '');
    qEl?.removeAttribute('hidden');
    renderQ();
  });

  document.getElementById('detailsForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const f = e.target as HTMLFormElement;
    if (!f.reportValidity()) return;
    const d = new FormData(f);
    if (d.get('website')) return; // honeypot tripped
    person = String(d.get('name') || '').trim();
    if (!org) org = String(d.get('company') || '').trim();
    fetch(LEAD_ENDPOINT, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: String(d.get('email') || '').trim(),
        name: person,
        company: String(d.get('company') || '').trim(),
        source: 'roadmap',
      }),
    }).catch(() => { /* never block the scorecard on network */ });
    detailsEl?.setAttribute('hidden', '');
    report();
  });

  function renderQ() {
    const q = QS[idx];
    $('qBar').style.width = `${(idx / QS.length) * 100}%`;
    $('qDim').textContent = `${DIMS[q.d]} · ${idx + 1} of ${QS.length}`;
    $('qText').textContent = q.q;
    const wrap = $('qOptions');
    wrap.innerHTML = '';
    q.o.forEach((opt, score) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'q-opt';
      b.innerHTML = `<span class="q-opt-key">${String.fromCharCode(65 + score)}</span><span>${esc(opt)}</span>`;
      b.addEventListener('click', () => {
        answers[idx] = score;
        idx += 1;
        if (idx < QS.length) renderQ();
        else {
          qEl?.setAttribute('hidden', '');
          detailsEl?.removeAttribute('hidden');
          (document.getElementById('dName') as HTMLInputElement)?.focus({ preventScroll: true });
        }
      });
      wrap.appendChild(b);
    });
    wrap.querySelector('button')?.focus({ preventScroll: true });
  }

  const stageOf = (pct, stages) => stages[Math.min(stages.length - 1, Math.floor(pct * stages.length))];

  function report() {
    const dims = [0, 1, 2, 3].map((d) =>
      QS.reduce((sum, q, i) => sum + (q.d === d ? answers[i] : 0), 0) / 9
    );
    const total = dims.reduce((a, b) => a + b, 0) / 4;
    const pct = Math.round(total * 100);
    const grade = GRADES.find((g) => total >= g.min);

    const lead = stageOf(dims[0], LEAD_STAGES);
    const orgStage = stageOf(dims[1], ORG_STAGES);
    const adopt = stageOf((dims[1] + dims[2]) / 2, ADOPT_STAGES);
    const train = stageOf((dims[0] + dims[2]) / 2, TRAIN_STAGES);

    const order = dims.map((v, i) => [v, i]).sort((a, b) => a[0] - b[0]).map(([, i]) => i);
    const weakest = DIMS[order[0]].toLowerCase();
    const strongest = DIMS[order[3]].toLowerCase();
    const horizon = total < 0.34 ? 4 : total < 0.6 ? 3 : 2;
    const today = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

    // Gauge geometry: 270° arc, r=84
    const R = 84, CIRC = 2 * Math.PI * R, ARC = CIRC * 0.75;

    const stageCard = (label, val, stages, i) => `
      <div class="sc-stage" style="animation-delay:${0.15 + i * 0.12}s">
        <span class="sc-stage-label">${label}</span>
        <span class="sc-stage-val">${val}</span>
        <span class="sc-steps">${stages.map((s) => `<i class="${s === val ? 'on' : ''}" title="${esc(s)}"></i>`).join('')}</span>
        <span class="sc-stage-pos">Stage ${stages.indexOf(val) + 1} of ${stages.length}</span>
      </div>`;

    const item = (x, n) => `
      <div class="sc-item" style="animation-delay:${0.2 + n * 0.1}s">
        <b>${esc(x.h)}</b><p>${esc(x.b)}</p>
      </div>`;

    $('report').innerHTML = `
      <div class="sc-frame">
        <header class="sc-head">
          <div>
            <p class="sc-kicker">AI Leadership Scorecard</p>
            <h2 class="sc-title">${esc(org || 'Your organisation')}</h2>
            <p class="sc-sub">Prepared for ${esc(person || 'you')} · ${today}</p>
          </div>
          <div class="sc-actions">
            <button class="btn btn--ghost" id="printBtn">Save as PDF</button>
            <button class="btn btn--ghost" id="retakeBtn">Retake</button>
          </div>
        </header>

        <div class="sc-hero">
          <div class="sc-gauge">
            <svg viewBox="0 0 200 200">
              <g transform="rotate(135 100 100)">
                <circle cx="100" cy="100" r="${R}" fill="none" stroke="rgba(167,216,196,0.12)" stroke-width="14"
                  stroke-dasharray="${ARC} ${CIRC}" stroke-linecap="round"/>
                <circle id="gaugeArc" cx="100" cy="100" r="${R}" fill="none" stroke="url(#gaugeGrad)" stroke-width="14"
                  stroke-dasharray="0 ${CIRC}" stroke-linecap="round"/>
              </g>
              <defs>
                <linearGradient id="gaugeGrad" x1="0" y1="1" x2="1" y2="0">
                  <stop offset="0" stop-color="#065f46"/>
                  <stop offset="1" stop-color="#34d399"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="sc-gauge-centre">
              <span class="sc-score"><span id="scoreNum">0</span><small>%</small></span>
              <span class="sc-score-label">overall readiness</span>
            </div>
          </div>
          <div class="sc-verdict">
            <span class="sc-grade">${grade.g}</span>
            <h3 class="sc-grade-label">${grade.label}</h3>
            <p>Your strongest dimension is <b>${esc(strongest)}</b>. The one that will repay attention
            first is <b>${esc(weakest)}</b>. You sit at the <b>${esc(adopt.toLowerCase())}</b> phase of the
            change curve, and the moves below are sequenced to take you to the next stage.</p>
          </div>
        </div>

        <div class="sc-stages">
          ${stageCard('Leadership maturity', lead, LEAD_STAGES, 0)}
          ${stageCard('Organisational maturity', orgStage, ORG_STAGES, 1)}
          ${stageCard('Change adoption', adopt, ADOPT_STAGES, 2)}
          ${stageCard('Training & capability', train, TRAIN_STAGES, 3)}
        </div>

        <div class="sc-panel sc-dims">
          <h3 class="sc-panel-title">Dimension scores</h3>
          ${dims.map((v, i) => `
            <div class="sc-bar-row">
              <span class="sc-bar-name">${DIMS[i]}</span>
              <div class="sc-bar"><div class="sc-bar-fill" data-w="${Math.max(4, v * 100)}" style="transition-delay:${0.3 + i * 0.15}s"></div></div>
              <b class="sc-bar-val">${Math.round(v * 100)}%</b>
            </div>`).join('')}
        </div>

        <div class="sc-grid">
          <div class="sc-panel">
            <h3 class="sc-panel-title">Leadership blindspots</h3>
            ${order.slice(0, 2).map((i, n) => item(BLIND[i], n)).join('')}
          </div>
          <div class="sc-panel">
            <h3 class="sc-panel-title">Where the value is</h3>
            ${[OPPS[order[0]], OPPS[order[3]]].map((x, n) => item(x, n)).join('')}
          </div>
        </div>

        <div class="sc-panel">
          <h3 class="sc-panel-title">The cost of inaction</h3>
          <div class="sc-timeline">
            ${RISKS.slice(0, horizon).map(([h, b], n) => `
              <div class="sc-tl-item" style="animation-delay:${0.2 + n * 0.12}s">
                <span class="sc-tl-when">${h}</span>
                <p>${b}</p>
              </div>`).join('')}
          </div>
        </div>

        <div class="sc-panel">
          <h3 class="sc-panel-title">Recommended next steps</h3>
          <div class="sc-recs">
            ${[...new Set([order[0], 0, order[1], order[2]])].slice(0, 4).map((i, n) => `
              <div class="sc-rec" style="animation-delay:${0.15 + n * 0.12}s">
                <span class="sc-rec-n">${n + 1}</span>
                <div><b>${esc(RECS[i].h)}</b><p>${esc(RECS[i].b)}</p></div>
              </div>`).join('')}
          </div>
        </div>

        <div class="sc-cta">
          <h2 style="max-width:20ch;margin-inline:auto">Want this turned into a plan?</h2>
          <p class="lead" style="margin:14px auto 28px">Book a complimentary 30-minute debrief. We walk your scorecard with you, pressure-test the findings and map your first 90 days.</p>
          <a class="btn btn--solid btn--lg" href="/contact/">Book a debrief</a>
        </div>
      </div>`;

    document.getElementById('quiz').hidden = true;
    const rep = $('report');
    rep.hidden = false;

    // Animate: gauge sweep + score count-up + bar fills
    requestAnimationFrame(() => {
      const arc = document.getElementById('gaugeArc');
      if (arc) {
        arc.style.transition = 'stroke-dasharray 1.4s cubic-bezier(0.22, 1, 0.36, 1)';
        requestAnimationFrame(() => arc.setAttribute('stroke-dasharray', `${ARC * total} ${CIRC}`));
      }
      document.querySelectorAll('.sc-bar-fill').forEach((el) => {
        requestAnimationFrame(() => { (el as HTMLElement).style.width = el.getAttribute('data-w') + '%'; });
      });
      const num = document.getElementById('scoreNum');
      const t0 = performance.now();
      const tick = (t) => {
        const p = Math.min(1, (t - t0) / 1400);
        const eased = 1 - Math.pow(1 - p, 3);
        if (num) num.textContent = String(Math.round(pct * eased));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });

    document.getElementById('printBtn')?.addEventListener('click', () => window.print());
    document.getElementById('retakeBtn')?.addEventListener('click', () => {
      answers.fill(-1); idx = 0;
      rep.hidden = true;
      rep.innerHTML = '';
      document.getElementById('quiz').hidden = false;
      introEl?.removeAttribute('hidden');
      qEl?.setAttribute('hidden', '');
      detailsEl?.setAttribute('hidden', '');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    rep.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>

<!-- Global on purpose: the quiz options and the entire scorecard are injected
     at runtime, so Astro-scoped selectors would never match them. -->
<style is:global>
  .quiz { max-width: 780px; margin: 0 auto; min-height: 380px; }
  .dims { list-style: none; padding: 0; margin: 0; }
  .dims li { padding: 10px 0 10px 26px; border-bottom: 1px solid var(--line); color: var(--mist); position: relative; font-size: 15.5px; }
  .dims li::before { content: '→'; position: absolute; left: 0; color: var(--emerald); font-weight: 700; }
  .dims b { color: var(--cream); }
  #startBtn { margin-top: 6px; }

  .q-progress { height: 4px; background: var(--line); border-radius: 2px; margin-bottom: 30px; overflow: hidden; }
  .q-bar { height: 100%; background: linear-gradient(90deg, var(--forest), var(--emerald)); transition: width 0.35s ease; }
  .q-dim { font-size: 12.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--emerald); margin-bottom: 10px; }
  .q-options { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
  .q-opt {
    display: flex; align-items: center; gap: 16px;
    font: 500 16px/1.45 var(--font);
    text-align: left;
    color: var(--cream);
    background: rgba(167, 216, 196, 0.04);
    border: 1.5px solid var(--line-strong);
    border-radius: 14px;
    padding: 16px 20px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .q-opt:hover, .q-opt:focus-visible {
    border-color: var(--emerald);
    background: rgba(5, 150, 105, 0.12);
    transform: translateX(6px);
    outline: none;
  }
  .q-opt-key {
    flex: none;
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 9px;
    border: 1.5px solid var(--line-strong);
    color: var(--sage); font-size: 13px; font-weight: 700;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .q-opt:hover .q-opt-key, .q-opt:focus-visible .q-opt-key { background: var(--emerald); border-color: var(--emerald); color: #fff; }

  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 480px) { .two { grid-template-columns: 1fr; } }
  .d-hp { position: absolute; left: -9999px; width: 1px; height: 1px; }

  /* ── Scorecard ───────────────────────────────────────────── */
  @keyframes sc-rise { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }
  .sc-frame { max-width: 980px; margin: 0 auto; }
  .sc-head {
    display: flex; flex-wrap: wrap; gap: 18px; align-items: flex-end; justify-content: space-between;
    padding-bottom: 26px; border-bottom: 1px solid var(--line); margin-bottom: 34px;
    animation: sc-rise 0.6s ease both;
  }
  .sc-kicker { font-size: 12.5px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--emerald); margin: 0 0 10px; }
  .sc-title { font-size: clamp(28px, 3.6vw, 46px); margin: 0; }
  .sc-sub { font-size: 14px; color: var(--faint); margin: 8px 0 0; }
  .sc-actions { display: flex; gap: 10px; }
  .sc-actions .btn { padding: 12px 20px; font-size: 14px; }

  .sc-hero {
    display: grid; grid-template-columns: 280px 1fr; gap: clamp(26px, 4vw, 60px); align-items: center;
    padding: clamp(26px, 3.5vw, 46px);
    border: 1px solid var(--line-strong); border-radius: 22px;
    background:
      radial-gradient(110% 140% at 0% 0%, rgba(5, 150, 105, 0.16), transparent 55%),
      linear-gradient(160deg, var(--pine), var(--onyx));
    animation: sc-rise 0.6s 0.05s ease both;
  }
  @media (max-width: 760px) { .sc-hero { grid-template-columns: 1fr; justify-items: center; text-align: center; } }
  .sc-gauge { position: relative; width: 100%; max-width: 280px; }
