---
import Base from '../layouts/Base.astro';
// AI Leadership Roadmap — the rebuilt diagnostic. The original Typebot version
// asked 36 questions and round-tripped three LLM prompts; this version asks 12
// (three per dimension), scores deterministically client-side, and renders the
// full report instantly on the page. The report sections mirror the original
// 11-section structure. (Research source: research/assessment-flow.txt.)
---
<Base title="AI Leadership Roadmap | Executive AI Institute" description="A free diagnostic for senior leaders: answer 12 questions and get your AI leadership maturity stage, blindspots, opportunities and recommendations — instantly, no sign-up.">
  <section class="section container" style="padding-top:160px;padding-bottom:40px">
    <span class="kicker">Free diagnostic · 3 minutes</span>
    <h1 style="max-width:15ch">Your AI Leadership <span class="accent">Roadmap.</span></h1>
    <p class="lead" style="margin-top:24px">
      Twelve questions across four dimensions — leadership readiness, organisational maturity,
      culture &amp; adoption, governance &amp; risk. There are no right or wrong answers: your responses
      reveal strengths, gaps and the next moves on your AI journey. Instant report, no sign-up.
    </p>
  </section>

  <section class="container" style="padding-bottom:120px">
    <div id="quiz" class="card quiz">
      <!-- Intro -->
      <div class="q-step" data-step="intro">
        <h2 style="font-size:clamp(24px,2.6vw,34px)">Before we start</h2>
        <p>Answer for the organisation you lead or advise. The diagnostic measures:</p>
        <ul class="dims">
          <li><b>Leadership readiness</b> — your own grasp of AI and ability to direct it</li>
          <li><b>Organisational maturity</b> — what your organisation has actually done</li>
          <li><b>Culture &amp; adoption</b> — how your people respond to change</li>
          <li><b>Governance &amp; risk</b> — how you manage what can go wrong</li>
        </ul>
        <div class="field" style="max-width:420px;margin-top:26px">
          <label for="orgname">Organisation name <span style="color:var(--faint);text-transform:none;letter-spacing:0">(optional — personalises your report)</span></label>
          <input id="orgname" type="text" autocomplete="organization" placeholder="e.g. Meridian Group" />
        </div>
        <button class="btn btn--solid btn--lg" id="startBtn">Begin the diagnostic</button>
      </div>

      <!-- Questions injected here -->
      <div class="q-step" data-step="question" hidden>
        <div class="q-progress"><div class="q-bar" id="qBar"></div></div>
        <p class="q-dim" id="qDim"></p>
        <h2 class="q-text" id="qText" style="font-size:clamp(22px,2.4vw,30px)"></h2>
        <div class="q-options" id="qOptions" role="group"></div>
      </div>

      <!-- Details gate: report unlocks with name, work email and company -->
      <div class="q-step" data-step="details" hidden>
        <div class="q-progress"><div class="q-bar" style="width:100%"></div></div>
        <p class="q-dim">One last step</p>
        <h2 style="font-size:clamp(22px,2.4vw,30px)">Your report is ready — who is it for?</h2>
        <p>We prepare the report under your name and company, and email you a copy so you can share it with your leadership team.</p>
        <form id="detailsForm" novalidate>
          <div class="two">
            <div class="field">
              <label for="dName">Full name *</label>
              <input id="dName" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="dCompany">Company *</label>
              <input id="dCompany" name="company" type="text" required autocomplete="organization" />
            </div>
          </div>
          <div class="field">
            <label for="dEmail">Work email *</label>
            <input id="dEmail" name="email" type="email" required autocomplete="email" />
          </div>
          <!-- Honeypot -->
          <input class="d-hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button class="btn btn--solid btn--lg" type="submit">Show my report</button>
          <p style="font-size:13px;color:var(--faint);margin:14px 0 0">We'll only use this to send your report and occasional leadership briefings. Unsubscribe any time. <a href="/privacy/">Privacy policy</a>.</p>
        </form>
      </div>
    </div>

    <!-- Report -->
    <div id="report" hidden>
      <div class="r-head">
        <span class="kicker">Your report</span>
        <h2 id="rTitle" style="max-width:20ch">AI Leadership Roadmap</h2>
        <p class="lead" id="rSummary"></p>
        <div class="r-actions">
          <button class="btn btn--ghost" id="printBtn">Save as PDF</button>
          <button class="btn btn--ghost" id="retakeBtn">Retake</button>
        </div>
      </div>

      <div class="r-stages" id="rStages"></div>

      <div class="r-grid">
        <div class="card">
          <h3 style="color:var(--sage)">Dimension scores</h3>
          <div id="rBars"></div>
        </div>
        <div class="card">
          <h3 style="color:var(--sage)">Leadership blindspots</h3>
          <div id="rBlind"></div>
        </div>
        <div class="card">
          <h3 style="color:var(--sage)">Organisational AI opportunities</h3>
          <div id="rOpps"></div>
        </div>
        <div class="card">
          <h3 style="color:var(--sage)">The cost of inaction</h3>
          <div id="rRisk"></div>
        </div>
      </div>

      <div class="card" style="margin-top:22px">
        <h3 style="color:var(--sage)">Recommended next steps</h3>
        <div id="rRecs"></div>
      </div>

      <div class="r-cta">
        <h2 style="max-width:20ch">Want this turned into a plan?</h2>
        <p class="lead" style="margin-bottom:28px">Book a complimentary 30-minute debrief and we'll walk your report, pressure-test the findings and map your first 90 days.</p>
        <a class="btn btn--solid btn--lg" href="/contact/">Book a debrief</a>
      </div>
    </div>
  </section>
</Base>

<script>
  // ── Question bank: 4 dimensions × 3 questions, options scored 0–3 ──
  const DIMS = ['Leadership readiness', 'Organisational maturity', 'Culture & adoption', 'Governance & risk'];
  const QS = [
    { d: 0, q: 'How confident are you in explaining core AI concepts to your team?',
      o: ['Not confident at all', 'Somewhat unsure', 'Fairly confident', 'Very confident'] },
    { d: 0, q: 'Which best describes your current AI knowledge?',
      o: ['No knowledge', 'Basic awareness of the terms', 'Moderate understanding of uses and limits', 'Deep understanding of strategy and ethics'] },
    { d: 0, q: 'How well can your leadership articulate why AI matters to your top business goals?',
      o: ['We haven’t connected the two', 'In broad strokes only', 'For some functions, clearly', 'A crisp, shared narrative across the exec team'] },
    { d: 1, q: 'Which step has your organisation already taken toward AI?',
      o: ['None', 'Informal research or discussion', 'A small pilot or proof-of-concept', 'Multiple pilots or early deployments'] },
    { d: 1, q: 'How well do you understand your organisation’s data, technology and process limits for deploying AI?',
      o: ['Not at all', 'A rough sense', 'Mapped for key functions', 'Mapped, owned and regularly reviewed'] },
    { d: 1, q: 'When planning AI initiatives, how often are they linked to specific KPIs or ROI targets?',
      o: ['Never — we haven’t planned any', 'Rarely', 'Usually', 'Always — it’s a gate for funding'] },
    { d: 2, q: 'How does your organisation react when someone says “we should try AI”?',
      o: ['Resistant — not interested', 'Resistant but curious — needs proof', 'Open with caution — needs more info', 'Very open — let’s do it'] },
    { d: 2, q: 'How easily does your team pick up new digital skills?',
      o: ['Very hard', 'Somewhat hard', 'Somewhat easy', 'Very easy'] },
    { d: 2, q: 'How often do teams share tips and help each other with new tools?',
      o: ['Never', 'Sometimes', 'Often', 'Always'] },
    { d: 3, q: 'Which best describes your approach to managing AI-related risks?',
      o: ['We haven’t considered them', 'Ad hoc — handled if they appear', 'Defined guidelines for key risks', 'A living governance framework with clear owners'] },
    { d: 3, q: 'How often do you invite outside experts or sceptics to challenge your AI plans?',
      o: ['Never', 'Rarely', 'Sometimes', 'Frequently'] },
    { d: 3, q: 'How are mistakes made with a new tool treated?',
      o: ['Someone gets blamed', 'Quietly buried', 'Tolerated', 'Examined openly as learning material'] },
  ];

  const LEAD_STAGES = ['Emerging', 'Strategic', 'Governance', 'Transformative'];
  const ORG_STAGES = ['Exploratory', 'Foundational', 'Integrated', 'Transformational'];
  const ADOPT_STAGES = ['Unaware', 'Skepticism', 'Exploration & piloting', 'Adoption & integration', 'Institutionalised'];
  const TRAIN_STAGES = ['Awareness & strategy', 'Leadership development', 'Organisational capability', 'Continuous learning'];

  const BLIND = [
    { h: 'Fluency gap', b: 'Leadership conviction is running ahead of leadership understanding — strategy set today will be inherited from vendors, not chosen.' },
    { h: 'Invisible foundations', b: 'Ambition is outpacing knowledge of your own data, process and technology limits — the most common cause of stalled pilots.' },
    { h: 'Quiet resistance', b: 'Initiatives are being green-lit faster than the culture can absorb them; adoption will lag announcement.' },
    { h: 'Unowned risk', b: 'No one is formally accountable for AI risk — fine until the first incident, expensive afterwards.' },
  ];
  const OPPS = [
    { h: 'Leadership upskilling', b: 'A structured executive AI fluency program converts enthusiasm into judgement — the fastest-compounding investment available to you.' },
    { h: 'Process quick wins', b: 'Manual, repeatable work in your operations is the natural first deployment: visible value in weeks, low risk, high learning.' },
    { h: 'Champion network', b: 'Your most curious people are an unbuilt asset — a champions program turns scattered experimentation into organisational capability.' },
    { h: 'Governance as advantage', b: 'Codifying how you evaluate, approve and monitor AI use builds the trust — internal and external — that accelerates everything else.' },
  ];
  const RECS = [
    { h: 'Executive briefing', b: 'Run a cost-of-inaction briefing with the full leadership team to build a shared, realistic baseline.' },
    { h: 'Readiness audit', b: 'Map your data, technology and process constraints before committing to any flagship initiative.' },
    { h: 'Pilot with guardrails', b: 'Launch one scoped pilot tied to a named KPI, with oversight rules agreed before kick-off.' },
    { h: 'Capability cadence', b: 'Stand up a regular upskilling rhythm — micro-labs, not one-off training days — so capability compounds.' },
  ];
  const RISKS = [
    ['Within 1 year', 'Operational inefficiencies persist while competitors automate; the best digitally-fluent talent starts choosing employers who are visibly moving.'],
    ['Within 3 years', 'Competitive dynamics shift: rivals price and respond on AI-assisted cost curves you cannot match, and market share erosion accelerates.'],
    ['Within 5 years', 'Strategic obsolescence sets in — product cycles, customer expectations and margins are set by AI-native operators in your sector.'],
    ['Within 10 years', 'Catch-up costs exceed transformation costs several times over; the question becomes viability, not advantage.'],
  ];

  // ── State ──
  const answers = new Array(QS.length).fill(-1);
  let idx = 0;
  let org = '';

  // Lead capture: results unlock with name + work email + company. Submissions
  // post to the Brew signup funnel (same route as Subscribe) tagged
  // source=roadmap; network failure never blocks the report.
  const LEAD_ENDPOINT = 'https://kamino.taila07ff3.ts.net/eaii-signup/pending';

  const $ = (id) => document.getElementById(id);
  const introEl = document.querySelector('[data-step="intro"]');
  const qEl = document.querySelector('[data-step="question"]');
  const detailsEl = document.querySelector('[data-step="details"]');

  $('startBtn')?.addEventListener('click', () => {
    org = ($('orgname') as HTMLInputElement).value.trim();
    introEl?.setAttribute('hidden', '');
    qEl?.removeAttribute('hidden');
    renderQ();
  });

  document.getElementById('detailsForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const f = e.target as HTMLFormElement;
    if (!f.reportValidity()) return;
    const d = new FormData(f);
    if (d.get('website')) return; // honeypot tripped
    if (!org) org = String(d.get('company') || '').trim();
    fetch(LEAD_ENDPOINT, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: String(d.get('email') || '').trim(),
        name: String(d.get('name') || '').trim(),
        company: String(d.get('company') || '').trim(),
        source: 'roadmap',
      }),
    }).catch(() => { /* never block the report on network */ });
    detailsEl?.setAttribute('hidden', '');
    report();
  });

  function renderQ() {
    const q = QS[idx];
    $('qBar').style.width = `${(idx / QS.length) * 100}%`;
    $('qDim').textContent = `${DIMS[q.d]} · ${idx + 1} of ${QS.length}`;
    $('qText').textContent = q.q;
    const wrap = $('qOptions');
    wrap.innerHTML = '';
    q.o.forEach((opt, score) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'q-opt';
      b.textContent = opt;
      b.addEventListener('click', () => {
        answers[idx] = score;
        idx += 1;
        if (idx < QS.length) renderQ();
        else {
          // All questions answered — gate the report behind contact details
          qEl?.setAttribute('hidden', '');
          detailsEl?.removeAttribute('hidden');
          (document.getElementById('dName') as HTMLInputElement)?.focus({ preventScroll: true });
        }
      });
      wrap.appendChild(b);
    });
    wrap.querySelector('button')?.focus({ preventScroll: true });
  }

  const stageOf = (pct, stages) => stages[Math.min(stages.length - 1, Math.floor(pct * stages.length))];

  function report() {
    // Dimension scores 0–9 → percentages
    const dims = [0, 1, 2, 3].map((d) =>
      QS.reduce((sum, q, i) => sum + (q.d === d ? answers[i] : 0), 0) / 9
    );
    const total = dims.reduce((a, b) => a + b, 0) / 4;

    const lead = stageOf(dims[0], LEAD_STAGES);
    const orgStage = stageOf(dims[1], ORG_STAGES);
    const adopt = stageOf((dims[1] + dims[2]) / 2, ADOPT_STAGES);
    const train = stageOf((dims[0] + dims[2]) / 2, TRAIN_STAGES);

    document.getElementById('quiz').hidden = true;
    const rep = $('report');
    rep.hidden = false;

    $('rTitle').textContent = org ? `${org}: AI Leadership Roadmap` : 'Your AI Leadership Roadmap';
    const weakest = DIMS[dims.indexOf(Math.min(...dims))].toLowerCase();
    const strongest = DIMS[dims.indexOf(Math.max(...dims))].toLowerCase();
    $('rSummary').textContent =
      `Overall readiness: ${(total * 100).toFixed(0)}%. Your leadership maturity reads as ${lead.toLowerCase()}, ` +
      `your organisation as ${orgStage.toLowerCase()}, and you sit at the ${adopt.toLowerCase()} phase of the change curve. ` +
      `Your strongest dimension is ${strongest}; the one that will repay attention first is ${weakest}.`;

    $('rStages').innerHTML = [
      ['Leadership maturity', lead, LEAD_STAGES],
      ['Organisational maturity', orgStage, ORG_STAGES],
      ['Change adoption', adopt, ADOPT_STAGES],
      ['Training & capability', train, TRAIN_STAGES],
    ].map(([label, val, stages]) => `
      <div class="stage card">
        <span class="stage-label">${label}</span>
        <span class="stage-val">${val}</span>
        <span class="stage-scale">${(stages as string[]).map((s) => `<i class="${s === val ? 'on' : ''}"></i>`).join('')}</span>
      </div>`).join('');

    $('rBars').innerHTML = dims.map((v, i) => `
      <div class="bar-row">
        <span>${DIMS[i]}</span>
        <div class="bar"><div style="width:${Math.max(4, v * 100)}%"></div></div>
        <b>${(v * 100).toFixed(0)}%</b>
      </div>`).join('');

    // Blindspots: the two weakest dimensions. Opportunities: weakest + strongest
    // (build on strength). Recommendations: ordered weakest-first; upskilling
    // always present (RECS[0] covers leadership).
    const order = dims.map((v, i) => [v, i]).sort((a, b) => a[0] - b[0]).map(([, i]) => i);
    const item = (x) => `<div class="r-item"><b>${x.h}</b><p>${x.b}</p></div>`;
    $('rBlind').innerHTML = order.slice(0, 2).map((i) => item(BLIND[i])).join('');
    $('rOpps').innerHTML = [OPPS[order[0]], OPPS[order[3]]].map(item).join('');
    $('rRecs').innerHTML = `<div class="recs">${[...new Set([order[0], 0, order[1], order[2]])].slice(0, 4)
      .map((i, n) => `<div class="r-item"><b><span class="rec-n">${n + 1}</span>${RECS[i].h}</b><p>${RECS[i].b}</p></div>`).join('')}</div>`;

    // Inaction risk scales with how early-stage the org is
    const horizon = total < 0.34 ? 4 : total < 0.6 ? 3 : 2;
    $('rRisk').innerHTML = RISKS.slice(0, horizon).map(([h, b]) => `<div class="r-item"><b>${h}</b><p>${b}</p></div>`).join('');

    rep.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  $('printBtn')?.addEventListener('click', () => window.print());
  $('retakeBtn')?.addEventListener('click', () => {
    answers.fill(-1); idx = 0;
    $('report').hidden = true;
    document.getElementById('quiz').hidden = false;
    introEl?.removeAttribute('hidden');
    qEl?.setAttribute('hidden', '');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<style>
  .quiz { max-width: 780px; margin: 0 auto; min-height: 380px; }
  .dims { list-style: none; padding: 0; margin: 0; }
  .dims li { padding: 10px 0 10px 26px; border-bottom: 1px solid var(--line); color: var(--mist); position: relative; font-size: 15.5px; }
  .dims li::before { content: '→'; position: absolute; left: 0; color: var(--emerald); font-weight: 700; }
  .dims b { color: var(--cream); }

  .q-progress { height: 4px; background: var(--line); border-radius: 2px; margin-bottom: 30px; overflow: hidden; }
  .q-bar { height: 100%; background: linear-gradient(90deg, var(--forest), var(--emerald)); transition: width 0.35s ease; }
  .q-dim { font-size: 12.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--emerald); margin-bottom: 10px; }
  .q-options { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
  .q-opt {
    font: 500 16px/1.45 var(--font);
    text-align: left;
    color: var(--cream);
    background: var(--onyx);
    border: 1.5px solid var(--line-strong);
    border-radius: 12px;
    padding: 16px 20px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .q-opt:hover, .q-opt:focus-visible { border-color: var(--emerald); background: rgba(5, 150, 105, 0.1); transform: translateX(4px); outline: none; }

  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 480px) { .two { grid-template-columns: 1fr; } }
  .d-hp { position: absolute; left: -9999px; width: 1px; height: 1px; }

  .r-head { max-width: 820px; margin: 20px auto 36px; text-align: center; }
  .r-head .kicker { justify-content: center; }
  .r-head .lead { margin-inline: auto; }
  .r-actions { display: flex; gap: 12px; justify-content: center; margin-top: 24px; }

  .r-stages { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 22px; }
  @media (max-width: 1000px) { .r-stages { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .r-stages { grid-template-columns: 1fr; } }
  .stage { padding: 22px; display: flex; flex-direction: column; gap: 8px; }
  .stage-label { font-size: 12px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); }
  .stage-val { font-size: clamp(20px, 1.8vw, 24px); font-weight: 700; color: var(--sage); letter-spacing: -0.01em; }
  .stage-scale { display: flex; gap: 5px; margin-top: 6px; }
  .stage-scale i { height: 5px; flex: 1; border-radius: 3px; background: var(--line-strong); }
  .stage-scale i.on { background: var(--emerald); box-shadow: 0 0 12px var(--glow); }

  .r-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  @media (max-width: 860px) { .r-grid { grid-template-columns: 1fr; } }

  .bar-row { display: grid; grid-template-columns: 1fr 140px 44px; align-items: center; gap: 14px; padding: 12px 0; border-bottom: 1px solid var(--line); font-size: 14.5px; }
  .bar-row:last-child { border-bottom: 0; }
  .bar-row span { color: var(--mist); }
  .bar-row b { color: var(--sage); text-align: right; }
  .bar { height: 8px; background: var(--line); border-radius: 4px; overflow: hidden; }
  .bar div { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--forest), var(--emerald)); }

  .r-item { padding: 14px 0; border-bottom: 1px solid var(--line); }
  .r-item:last-child { border-bottom: 0; }
  .r-item b { color: var(--cream); display: block; margin-bottom: 4px; }
  .r-item p { margin: 0; font-size: 15px; }
  .rec-n {
    display: inline-flex; align-items: center; justify-content: center;
    width: 26px; height: 26px; border-radius: 50%;
    border: 1.5px solid var(--emerald); color: var(--emerald);
    font-size: 13px; margin-right: 10px;
  }

  .r-cta { text-align: center; margin-top: 70px; }
  .r-cta h2 { margin-inline: auto; }
  .r-cta .lead { margin-inline: auto; }

  @media print {
    .site-header, .site-footer, .r-actions, .r-cta { display: none !important; }
    body { background: #fff; color: #111; }
    body::before { display: none; }
    .card { border-color: #ccc; background: #fff; }
    .stage-val, .r-item b { color: #065f46; }
    .r-item p, .bar-row span { color: #333; }
  }
</style>
