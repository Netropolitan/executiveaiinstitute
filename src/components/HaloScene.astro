---
// Three.js HALO framework: six pillar nodes on a tilted ring around a breathing
// wireframe core. Energy particles orbit the ring and light each pillar as they
// pass; labels are HTML projected from 3D space (crisp at any size, readable by
// screen readers). Pointer parallax on the whole formation. Falls back to a
// static SVG without WebGL or with reduced motion.
const PILLARS = [
  'Leadership Enablement',
  'AI Vision & Strategy',
  'Organization & Technology Architecture',
  'Implementation Governance',
  'Change Management',
  'Augmenting Human Capability',
];
---
<div class="halo-scene" data-pillars={JSON.stringify(PILLARS)}>
  <div class="halo-centre" aria-hidden="true">
    <b>HALO</b>
    <span>AI Digital<br />Transformation</span>
  </div>
  {PILLARS.map((p, i) => (
    <span class="halo-label" data-i={i}>{p}</span>
  ))}

  <svg class="halo-fallback" viewBox="0 0 560 520" fill="none" aria-hidden="true">
    <circle cx="280" cy="260" r="148" stroke="#0d7555" stroke-width="1.5" opacity="0.55" />
    <circle cx="280" cy="260" r="104" stroke="#059669" stroke-width="1.5" opacity="0.4" />
    <circle cx="280" cy="260" r="62" stroke="#a7d8c4" stroke-width="1.5" opacity="0.35" />
    {PILLARS.map((_, i) => {
      const a = (i / 6) * Math.PI * 2 - Math.PI / 2;
      return <circle cx={280 + Math.cos(a) * 148} cy={260 + Math.sin(a) * 148} r="8" fill="#059669" />;
    })}
  </svg>
</div>

<style>
  .halo-scene { position: relative; width: 100%; aspect-ratio: 1 / 0.92; max-width: 620px; }
  .halo-scene canvas { position: absolute; inset: 0; width: 100% !important; height: 100% !important; }
  .halo-fallback { width: 100%; height: 100%; }
  .halo-scene.live .halo-fallback { display: none; }

  .halo-centre {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: none;
    z-index: 2;
    display: none;
  }
  .halo-scene.live .halo-centre { display: block; }
  .halo-centre b { display: block; font-size: clamp(22px, 2.4vw, 30px); font-weight: 700; letter-spacing: 0.04em; color: var(--cream); }
  .halo-centre span { font-size: clamp(11px, 1vw, 13px); line-height: 1.35; color: var(--sage); font-weight: 500; }

  .halo-label {
    position: absolute;
    transform: translate(-50%, -50%);
    font-size: clamp(11.5px, 1.05vw, 14px);
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    max-width: 13ch;
    color: var(--sage);
    opacity: 0;
    pointer-events: none;
    z-index: 2;
    transition: color 0.4s ease, text-shadow 0.4s ease;
  }
  .halo-scene.live .halo-label { opacity: 1; }
  .halo-label.hot { color: var(--cream); text-shadow: 0 0 18px rgba(52, 211, 153, 0.9); }
</style>

<script>
  import * as THREE from 'three';

  const host = document.querySelector('.halo-scene') as HTMLElement;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (host && !reduced) {
    try {
      const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: 'low-power' });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      host.appendChild(renderer.domElement);
      host.classList.add('live');

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 60);
      camera.position.set(0, 1.7, 6.2);
      camera.lookAt(0, 0, 0);

      const group = new THREE.Group();
      group.rotation.x = 0.16; // tip the ring toward the viewer
      scene.add(group);

      const N = 6, R = 2.35;
      const nodeAngle = (i) => (i / N) * Math.PI * 2 - Math.PI / 2;
      const nodePos = (i) => new THREE.Vector3(Math.cos(nodeAngle(i)) * R, 0, Math.sin(nodeAngle(i)) * R);

      // Core: breathing wireframe icosahedron + inner glow sphere
      const core = new THREE.Mesh(
        new THREE.IcosahedronGeometry(0.95, 1),
        new THREE.MeshBasicMaterial({ color: 0x059669, wireframe: true, transparent: true, opacity: 0.55 })
      );
      group.add(core);
      const coreGlow = new THREE.Mesh(
        new THREE.SphereGeometry(0.55, 24, 24),
        new THREE.MeshBasicMaterial({ color: 0x065f46, transparent: true, opacity: 0.35 })
      );
      group.add(coreGlow);

      // Main ring + a second, offset ring for depth
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(R, 0.012, 8, 160),
        new THREE.MeshBasicMaterial({ color: 0x0d7555, transparent: true, opacity: 0.85 })
      );
      ring.rotation.x = Math.PI / 2;
      group.add(ring);

      const ring2 = new THREE.Mesh(
        new THREE.TorusGeometry(R * 1.22, 0.006, 8, 160),
        new THREE.MeshBasicMaterial({ color: 0x065f46, transparent: true, opacity: 0.4 })
      );
      ring2.rotation.x = Math.PI / 2 + 0.22;
      group.add(ring2);

      // Pillar nodes + halo rings + spokes to the core
      const nodes = [];
      for (let i = 0; i < N; i++) {
        const p = nodePos(i);
        const node = new THREE.Mesh(
          new THREE.SphereGeometry(0.1, 20, 20),
          new THREE.MeshBasicMaterial({ color: 0x059669 })
        );
        node.position.copy(p);
        group.add(node);

        const haloRing = new THREE.Mesh(
          new THREE.RingGeometry(0.16, 0.19, 40),
          new THREE.MeshBasicMaterial({ color: 0x34d399, transparent: true, opacity: 0.25, side: THREE.DoubleSide, depthWrite: false })
        );
        haloRing.rotation.x = Math.PI / 2;
        haloRing.position.copy(p);
        group.add(haloRing);

        const spoke = new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([p.clone().multiplyScalar(0.42), p.clone().multiplyScalar(0.95)]),
          new THREE.LineBasicMaterial({ color: 0x0d7555, transparent: true, opacity: 0.4 })
        );
        group.add(spoke);

        nodes.push({ node, haloRing, spoke, i });
      }

      // Energy particles flowing around the main ring
      const FLOW = 36;
      const flowGeo = new THREE.BufferGeometry();
      flowGeo.setAttribute('position', new THREE.Float32BufferAttribute(new Float32Array(FLOW * 3), 3));
      const flow = new THREE.Points(flowGeo, new THREE.PointsMaterial({
        color: 0x34d399, size: 0.055, transparent: true, opacity: 0.95, sizeAttenuation: true,
      }));
      group.add(flow);

      // Ambient dust for depth
      const dust = [];
      for (let i = 0; i < 70; i++) {
        const r = 0.6 + ((i * 0.37) % 1) * 3.2, a = i * 2.39996;
        dust.push(new THREE.Vector3(Math.cos(a) * r, (((i * 0.61) % 1) - 0.5) * 2.4, Math.sin(a) * r));
      }
      group.add(new THREE.Points(
        new THREE.BufferGeometry().setFromPoints(dust),
        new THREE.PointsMaterial({ color: 0x059669, size: 0.02, transparent: true, opacity: 0.45 })
      ));

      // Labels: project node positions to screen space each frame
      const labels = Array.from(host.querySelectorAll('.halo-label')) as HTMLElement[];
      const proj = new THREE.Vector3();

      let tx = 0, ty = 0;
      window.addEventListener('pointermove', (e) => {
        tx = (e.clientX / window.innerWidth - 0.5) * 0.25;
        ty = (e.clientY / window.innerHeight - 0.5) * 0.15;
      }, { passive: true });

      const size = () => {
        const w = host.clientWidth, h = host.clientHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      };
      size();
      window.addEventListener('resize', size);

      let visible = true;
      new IntersectionObserver(([e]) => { visible = e.isIntersecting; }).observe(host);

      const clock = new THREE.Clock();
      renderer.setAnimationLoop(() => {
        if (!visible) return;
        const t = clock.getElapsedTime();

        group.rotation.y = Math.sin(t * 0.12) * 0.22 + tx;
        group.rotation.x = 0.16 + ty * 0.6;
        core.rotation.y = t * 0.25;
        core.rotation.z = t * 0.1;
        const breathe = 1 + Math.sin(t * 1.1) * 0.05;
        core.scale.setScalar(breathe);
        (coreGlow.material as THREE.MeshBasicMaterial).opacity = 0.25 + (Math.sin(t * 1.1) + 1) * 0.1;
        ring2.rotation.z = t * 0.05;

        // Flow particles: three streams offset around the ring
        const arr = flowGeo.attributes.position.array as Float32Array;
        for (let i = 0; i < FLOW; i++) {
          const a = (i / FLOW) * Math.PI * 2 + t * 0.45;
          arr[i * 3] = Math.cos(a) * R;
          arr[i * 3 + 1] = Math.sin(a * 3 + t) * 0.04;
          arr[i * 3 + 2] = Math.sin(a) * R;
        }
        flowGeo.attributes.position.needsUpdate = true;

        // The "active" pillar cycles as the energy front passes each node
        const front = ((t * 0.45) % (Math.PI * 2));
        nodes.forEach(({ node, haloRing, i }) => {
          // node angle in flow terms (flow angle a==nodeAngle when front aligns)
          const na = ((nodeAngle(i) % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2);
          let d = Math.abs(((front - na + Math.PI * 3) % (Math.PI * 2)) - Math.PI);
          const heat = Math.max(0, 1 - d / 0.9);
          const mat = node.material as THREE.MeshBasicMaterial;
          mat.color.setHex(heat > 0.5 ? 0x9ff0cf : 0x059669);
          node.scale.setScalar(1 + heat * 0.7);
          const hm = haloRing.material as THREE.MeshBasicMaterial;
          hm.opacity = 0.2 + heat * 0.65;
          haloRing.scale.setScalar(1 + heat * 0.8);
          labels[i]?.classList.toggle('hot', heat > 0.55);
        });

        // Project labels just outside their nodes
        const w = host.clientWidth, h = host.clientHeight;
        nodes.forEach(({ i }) => {
          proj.copy(nodePos(i)).multiplyScalar(1.3);
          proj.applyMatrix4(group.matrixWorld);
          proj.project(camera);
          const el = labels[i];
          if (!el) return;
          // clamp inside the canvas so labels never bleed into page text
          const x = Math.min(0.93, Math.max(0.07, proj.x * 0.5 + 0.5)) * w;
          const y = Math.min(0.95, Math.max(0.05, -proj.y * 0.5 + 0.5)) * h;
          el.style.left = `${x}px`;
          el.style.top = `${y}px`;
        });

        renderer.render(scene, camera);
      });
    } catch (e) {
      /* WebGL unavailable; SVG fallback stays */
    }
  }
</script>
